{
  "name": "@35mm/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node --watch --env-file=../api/.env --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "backfill:media": "node --env-file=../api/.env --import tsx src/scripts/backfillMedia.ts",
    "backfill:avatars": "node --env-file=../api/.env --import tsx src/scripts/backfillProfileMedia.ts",
    "reconcile:counters": "node --env-file=../api/.env --import tsx src/scripts/reconcileCounters.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@35mm/db": "workspace:*",
    "@35mm/types": "workspace:*",
    "aws-sigv4-auth-cassandra-plugin": "^1.0.1",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "@aws-sdk/client-s3": "^3.774.0",
    "ably": "^2.5.0",
    "blurhash": "^2.0.5",
    "bullmq": "^5.58.5",
    "cassandra-driver": "^4.8.0",
    "drizzle-orm": "^0.45.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.16.0",
    "sharp": "^0.34.5",
    "ulid": "^2.4.0"
  },
  "devDependencies": {
    "@35mm/config": "workspace:*",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
