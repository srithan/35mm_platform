{
  "name": "@35mm/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file=../api/.env --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "backfill:media": "node --env-file=../api/.env --import tsx src/scripts/backfillMedia.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@35mm/db": "workspace:*",
    "@35mm/types": "workspace:*",
    "@aws-sdk/client-s3": "^3.774.0",
    "bullmq": "^5.58.5",
    "blurhash": "^2.0.5",
    "drizzle-orm": "^0.45.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@35mm/config": "workspace:*",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
