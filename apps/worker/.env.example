# Neon Postgres
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.neon.tech/neondb?sslmode=require

# Cloudflare R2 object storage
R2_ACCOUNT_ID=<r2-account-id>
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET=35mm-media
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev

# Optional Cloudflare Images delivery settings
CF_IMAGES_ACCOUNT_ID=
CF_IMAGES_API_TOKEN=
CF_IMAGES_ACCOUNT_HASH=
CF_IMAGES_DELIVERY_BASE_URL=
CF_IMAGES_DEFAULT_THUMB_VARIANT=public
CF_IMAGES_DEFAULT_FEED_VARIANT=public
CF_IMAGES_DEFAULT_FULL_VARIANT=public

# Ably realtime publisher for notifications and chat worker events
ABLY_API_KEY=

# Resend notification email delivery
RESEND_API_KEY=
EMAIL_FROM=35mm <notifications@35mm.app>
EMAIL_UNSUBSCRIBE_SECRET=
NOTIFICATION_EMAIL_COOLDOWN_MINUTES=60

# App/API links used in notification email content and worker callbacks
APP_BASE_URL=http://localhost:3000
API_PUBLIC_BASE_URL=http://localhost:4000

# Dedicated Upstash Redis credentials for BullMQ. Must match API queue Redis.
QUEUE_REDIS_URL=
QUEUE_REDIS_REST_URL=
QUEUE_REDIS_REST_TOKEN=

# Cache Redis used by chat/feed cache helpers. Never used for BullMQ.
UPSTASH_REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AWS Keyspaces chat messages
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
KEYSPACES_ENDPOINT=cassandra.us-east-1.amazonaws.com
KEYSPACES_CORE_CONNECTIONS=4
KEYSPACES_MAX_REQUESTS_PER_CONNECTION=1024
KEYSPACES_CONNECT_TIMEOUT_MS=3000
KEYSPACES_DEFAULT_TIMEOUT_MS=2000
KEYSPACES_READ_TIMEOUT_MS=2000
KEYSPACES_WRITE_TIMEOUT_MS=2000
KEYSPACES_HEARTBEAT_MS=30000

# Worker batch/concurrency tuning
WORKER_ENABLED=true
MEDIA_JOB_BATCH_SIZE=20
MEDIA_BACKFILL_BATCH_SIZE=100
WORKER_CONCURRENCY=4

# Feed fanout, scoring, and retention tuning
FEED_HIGH_FOLLOWER_THRESHOLD=10000
FEED_FANOUT_BATCH_SIZE=500
FEED_FANOUT_OUTBOX_BATCH_SIZE=100
FEED_FANOUT_OUTBOX_INTERVAL_SECONDS=15
FEED_FANOUT_OUTBOX_RETRY_BASE_MS=5000
FEED_FANOUT_OUTBOX_RETRY_MAX_MS=300000
FEED_RESCORE_MAX_AGE_HOURS=72
FEED_RESCORE_BATCH_SIZE=500
FEED_ITEMS_RETENTION_DAYS=30
FEED_ITEMS_PRUNE_BATCH_SIZE=5000
FEED_ITEMS_PRUNE_MAX_BATCHES=20
FEED_ITEMS_PRUNE_INTERVAL_MINUTES=60
