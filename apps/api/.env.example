# Neon Postgres (pooled connection string from Neon dashboard)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.neon.tech/neondb?sslmode=require

# Clerk (from Clerk dashboard → API Keys)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk webhook (from Clerk dashboard → Webhooks → Signing Secret)
CLERK_WEBHOOK_SECRET=whsec_...

# CORS origins (comma-separated Next.js app URLs)
CORS_ORIGIN=http://localhost:3000,https://35mm-platform-web.vercel.app

# Cloudflare R2 object storage (public bucket is "35mm-media")
R2_ACCOUNT_ID=<r2-account-id>
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET=35mm-media
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev
R2_PRESIGN_TTL_SECONDS=900

# Optional Cloudflare Images delivery settings (for variant naming + future imagedelivery.net wiring)
CF_IMAGES_ACCOUNT_ID=
CF_IMAGES_ACCOUNT_HASH=
CF_IMAGES_API_TOKEN=
CF_IMAGES_DELIVERY_BASE_URL=
CF_IMAGES_DEFAULT_THUMB_VARIANT=thumb
CF_IMAGES_DEFAULT_FEED_VARIANT=feed
CF_IMAGES_DEFAULT_FULL_VARIANT=full

# Upstash Redis REST (required for production feed cache)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash Redis TCP/Redis URL (required for BullMQ queue producer/worker)
UPSTASH_REDIS_URL=

# Set false in local sessions that must not start BullMQ worker polling against Upstash.
WORKER_ENABLED=true

# AWS Keyspaces chat messages
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
KEYSPACES_ENDPOINT=cassandra.us-east-1.amazonaws.com
KEYSPACES_CORE_CONNECTIONS=4
KEYSPACES_MAX_REQUESTS_PER_CONNECTION=1024
KEYSPACES_CONNECT_TIMEOUT_MS=3000
KEYSPACES_DEFAULT_TIMEOUT_MS=2000
KEYSPACES_READ_TIMEOUT_MS=2000
KEYSPACES_WRITE_TIMEOUT_MS=2000
KEYSPACES_HEARTBEAT_MS=30000

# Ably realtime (notification publisher)
ABLY_API_KEY=

# Optional local/dev override for throttling
RATE_LIMIT_DISABLED=false

# Server port
PORT=4000
