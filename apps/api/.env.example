# Neon Postgres (pooled connection string from Neon dashboard)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.neon.tech/neondb?sslmode=require

# Clerk (from Clerk dashboard → API Keys)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk webhook (from Clerk dashboard → Webhooks → Signing Secret)
CLERK_WEBHOOK_SECRET=whsec_...

# CORS origin (your Next.js app URL)
CORS_ORIGIN=http://localhost:3000

# Cloudflare R2 object storage (public bucket is "35mm-media")
R2_ACCOUNT_ID=<r2-account-id>
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET=35mm-media
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev
R2_PRESIGN_TTL_SECONDS=900

# Server port
PORT=4000
