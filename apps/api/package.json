{
  "name": "@35mm/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node --watch --env-file=.env --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "backfill:catalog-films": "node --env-file=.env --import tsx src/scripts/backfillFilmsToCatalog.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@35mm/db": "workspace:*",
    "@35mm/types": "workspace:*",
    "@35mm/validators": "workspace:*",
    "aws-sigv4-auth-cassandra-plugin": "^1.0.1",
    "cassandra-driver": "^4.8.0",
    "@clerk/backend": "^3.4.13",
    "@aws-sdk/client-s3": "^3.774.0",
    "@aws-sdk/s3-request-presigner": "^3.774.0",
    "@hono/node-server": "^1.13.8",
    "@neondatabase/serverless": "^1.1.0",
    "bullmq": "^5.58.5",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "open-graph-scraper": "^6.9.0",
    "svix": "^1.94.0"
  },
  "devDependencies": {
    "@35mm/config": "workspace:*",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "4.0.18"
  }
}
