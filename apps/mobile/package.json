{
  "name": "@35mm/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "packageManager": "pnpm@9.6.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "start": "node ./scripts/run-expo.mjs development start",
    "start:preview": "node ./scripts/run-expo.mjs preview start",
    "android": "node ./scripts/run-expo.mjs development run:android",
    "ios": "node ./scripts/run-expo.mjs development run:ios",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "config:check": "node ./scripts/validate-config.mjs",
    "native:expo-constants:check": "node ./scripts/verify-expo-constants-generation.mjs",
    "native:ios:artifact:check": "node ./scripts/verify-ios-release-artifact.mjs",
    "native:policy:check": "node ./scripts/validate-native-policy.mjs",
    "native:prebuild:check": "node ./scripts/verify-native-generation.mjs",
    "native:check": "pnpm native:expo-constants:check && pnpm native:policy:check && pnpm native:prebuild:check",
    "native:regenerate": "node ./scripts/regenerate-native.mjs",
    "quality:check": "node ./scripts/quality/validate-quality-harnesses.mjs",
    "e2e:foundation": "node ./scripts/quality/run-maestro.mjs smoke",
    "visual:test": "node ./scripts/quality/run-maestro.mjs visual",
    "performance:verify": "node ./scripts/quality/validate-performance-baseline.mjs",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --runInBand --coverage",
    "check:ci": "pnpm typecheck && pnpm lint && pnpm config:check && pnpm quality:check && pnpm native:check && pnpm test:ci"
  },
  "dependencies": {
    "@35mm/api-client": "workspace:*",
    "@35mm/design-tokens": "workspace:^",
    "@35mm/mobile-ui": "workspace:*",
    "@clerk/expo": "^4.0.1",
    "@expo-google-fonts/dm-mono": "0.4.2",
    "@expo-google-fonts/dm-sans": "0.4.2",
    "@expo-google-fonts/dm-serif-display": "0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@tanstack/query-async-storage-persister": "5.100.11",
    "@tanstack/react-query": "5.100.11",
    "@tanstack/react-query-persist-client": "5.100.11",
    "expo": "~57.0.8",
    "expo-build-properties": "~57.0.6",
    "expo-constants": "~57.0.7",
    "expo-crypto": "~57.0.1",
    "expo-dev-client": "~57.0.8",
    "expo-font": "~57.0.1",
    "expo-linking": "~57.0.4",
    "expo-router": "~57.0.8",
    "expo-secure-store": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "lucide-react-native": "1.25.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.26.0",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.10.0",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "@types/react-dom": "~19.2.3",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~57.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.2",
    "pngjs": "5.0.0",
    "yaml": "2.9.0",
    "typescript": "~6.0.3"
  }
}
