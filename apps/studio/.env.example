NEXT_PUBLIC_TMDB_API_KEY=
NEXT_PUBLIC_OMDB_API_KEY=

# Use a separate Clerk application for the platform Studio app.
# Do not copy keys from ../35mm_studio/.env or apps/web/.env.local.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Prefer read-only replica URL for Studio.
# Falls back to DATABASE_URL from platform/apps/api/.env in local monorepo dev.
STUDIO_DATABASE_URL=
