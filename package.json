{
  "name": "35mm-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.6.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @35mm/web --filter @35mm/api dev",
    "dev:all": "pnpm --parallel --filter @35mm/web --filter @35mm/api --filter @35mm/worker dev",
    "dev:web": "pnpm --filter @35mm/web dev",
    "dev:api": "pnpm --filter @35mm/api dev",
    "dev:worker": "pnpm --filter @35mm/worker dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.45.2"
  }
}
